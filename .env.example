# =============================================================================
# Compose variable substitution
# =============================================================================
# These variables are used by compose.yml and compose.dev.yml for Docker
# container defaults. They are NOT application configuration.
# Copy this file to .env and adjust if you need non-default values.
POSTGRES_DB=playvault
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# =============================================================================
# Development application config (.env.development)
# =============================================================================
# Copy this file to .env.development and adjust for your local setup.
# This file is committed and provides sane defaults for Docker development.
#
# DATABASE_URL — postgres connection string (use "db" hostname inside Docker)
# DATABASE_URL=postgresql://postgres:postgres@db:5432/playvault
#
# DIRECT_URL — direct connection for migrations (same as DATABASE_URL in dev)
# DIRECT_URL=postgresql://postgres:postgres@db:5432/playvault
#
# AUTH_SECRET — generate with: openssl rand -base64 32
# AUTH_SECRET=dev-auth-secret
#
# NEXT_PUBLIC_APP_URL — public URL of the app (for auth callbacks)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
#
# GOOGLE_SAFE_BROWSING_API_KEY — optional, for URL safety checks
# GOOGLE_SAFE_BROWSING_API_KEY=
#
# STORAGE_ENDPOINT — S3-compatible endpoint (MinIO dev, Supabase prod)
# STORAGE_ENDPOINT=http://minio:9000
#
# STORAGE_ACCESS_KEY — S3 access key
# STORAGE_ACCESS_KEY=minioadmin
#
# STORAGE_SECRET_KEY — S3 secret key
# STORAGE_SECRET_KEY=minioadmin
#
# STORAGE_BUCKET — S3 bucket name for thumbnails
# STORAGE_BUCKET=thumbnails
#
# STORAGE_PUBLIC_URL — public base URL for the bucket (browser-accessible)
# STORAGE_PUBLIC_URL=http://localhost:9000/thumbnails

# =============================================================================
# Production application config (.env.production — NOT committed)
# =============================================================================
# Create this file on your production server with real values.
# Do NOT commit it to version control.
#
# DATABASE_URL=postgresql://user:pass@host:5432/playvault
# DIRECT_URL=postgresql://user:pass@host:5432/playvault
# AUTH_SECRET=change-me-to-a-real-secret
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
# GOOGLE_SAFE_BROWSING_API_KEY=
#
# # Supabase Storage (S3-compatible)
# STORAGE_ENDPOINT=https://your-project.supabase.co/storage/v1/s3
# STORAGE_ACCESS_KEY=your-supabase-s3-access-key
# STORAGE_SECRET_KEY=your-supabase-s3-secret-key
# STORAGE_BUCKET=thumbnails
# STORAGE_PUBLIC_URL=https://your-project.supabase.co/storage/v1/object/public/thumbnails
