# =============================================================================
# Database
# =============================================================================
# DATABASE_URL     — Pooled connection for runtime queries.
#                    Local:   postgresql://postgres:postgres@localhost:5432/playvault
#                    Supabase: pooled connection string (port 6543)
# DIRECT_URL       — Direct connection for migrations only.
#                    Local:   postgresql://postgres:postgres@localhost:5432/playvault
#                    Supabase: direct connection string (port 5432)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/playvault"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/playvault"

# Docker Postgres credentials (used by docker-compose.yml)
POSTGRES_DB=playvault
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# =============================================================================
# Auth (Auth.js v5)
# =============================================================================
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-secret"

# Google OAuth — optional for now, required for Google sign-in
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# =============================================================================
# App
# =============================================================================
# Only vars prefixed NEXT_PUBLIC_ are available in the browser.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================================================
# URL Safety
# =============================================================================
# Google Safe Browsing API key — optional. Get one at:
# https://console.cloud.google.com/apis/library/safebrowsing.googleapis.com
# Free for non-commercial use. If unset, only the domain blocklist is used.
GOOGLE_SAFE_BROWSING_API_KEY=""
