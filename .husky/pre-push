#!/bin/sh
branch=$(git rev-parse --abbrev-ref HEAD)

# Allow dev to push anywhere
[ "$branch" = "dev" ] && exit 0

# Reject any push targeting refs/heads/main unless source is dev
while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    echo "❌ Direct push to main from '$branch' is not allowed."
    echo "   Use a PR: https://github.com/itsw1n/WinVault/compare/main...$branch"
    exit 1
  fi
done

exit 0
